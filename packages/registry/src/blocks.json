        "collapsible",
        "dropdown-menu",
        "separator",
        "sidebar"
      ],
      "files": [
        {
          "path": "examples/user-app-layout.tsx",
          "type": "registry:block",
          "target": "components/user-app-layout.tsx"
        }
      ]
    }
  ]
}
