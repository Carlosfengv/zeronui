{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "registry/**", "!.next/cache/**"]
    },
    "check": {
      "dependsOn": ["^check"]
    }
  }
}
